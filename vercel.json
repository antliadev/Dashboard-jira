{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/jira/sync.js": {
      "maxDuration": 300
    },
    "api/jira/sync/worker.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/jira/sync/worker",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
