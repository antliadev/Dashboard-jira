# Supabase (obrigatorio para importar e consultar tickets)
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Preferido em producao: uma chave backend privada.
# Use a service_role JWT ou sb_secret_*. Nao use PAT sbp_* aqui.
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_LEGADA_EYJ
# ou
SUPABASE_SECRET_KEY=SUA_SECRET_KEY_MODERNA_SB_SECRET

# Alternativa apenas para leitura/escrita quando as policies permitirem anon.
# Com anon, sync jobs nao conseguem persistir credenciais temporarias para recovery/worker.
SUPABASE_ANON_KEY=SUA_ANON_KEY_EYJ
SUPABASE_PUBLISHABLE_KEY=SUA_PUBLISHABLE_KEY_SB_PUBLISHABLE

# Segredos backend
JIRA_ENCRYPTION_KEY=SUA_CHAVE_AQUI_MINIMO_32_BYTES
AUTH_SESSION_SECRET=SUA_CHAVE_DE_SESSAO_MINIMO_32_BYTES
CRON_SECRET=SUA_CHAVE_DO_WORKER_MINIMO_32_BYTES

# Login do app
AUTH_EMAIL=admin@jira.com
AUTH_PASSWORD=admin123

PORT=3001
